# Normalize line endings to LF in the repo so Windows checkouts (core.autocrlf)
# don't re-introduce CRLF and trigger prettier "Delete ␍" errors on every line.
* text=auto eol=lf

# Keep binary assets untouched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
